---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const cvHref = `${base}assets/Ryan_Heejoon_Byun_CV.pdf`;

const interests = [
  'Conformal and distribution-free inference',
  'Prediction-powered and black-box-assisted inference',
  'Calibrated Bayesian and simulation-based inference',
  'Uncertainty quantification for scientific simulators and neural surrogates',
  'Inference under model misspecification and distribution shift'
];

const coursework = [
  'Graduate Probability Theory I-II',
  'Graduate Statistical Theory I-II',
  'Functional Analysis',
  'Differentiable Manifolds',
  'Mathematical Foundations of Deep Neural Networks',
  'Reinforcement Learning',
  'Information Theory'
];
---
<BaseLayout>
  <main class="page" id="top">
    <header class="site-header">
      <div class="identity">
        <h1>Ryan Heejoon Byun</h1>
        <p>M.S. student in Statistics, Seoul National University</p>
      </div>
      <nav class="nav" aria-label="Primary navigation">
        <a href="#research">Research</a>
        <a href="#publications">Publications</a>
        <a href="#teaching">Teaching</a>
        <a href="#education">Education</a>
        <a href={cvHref}>CV</a>
      </nav>
    </header>

    <section class="intro" aria-label="Introduction">
      <p>
        I am an M.S. student in Statistics at Seoul National University, advised by Professor Won Chang.
        My research interests are in statistical methodology for valid black-box-assisted inference: methods
        that use pretrained models, scientific simulators, neural surrogates, or synthetic data to improve
        inference while preserving calibrated uncertainty under model misspecification and distribution shift.
      </p>
      <p>
        Before joining the Statistics program, I received a B.S. in Electrical and Computer Engineering from
        Seoul National University. My background combines statistical inference, probability, machine learning,
        and scientific computation.
      </p>
      <p class="contact-links">
        <a href="mailto:ryanb01@snu.ac.kr">ryanb01@snu.ac.kr</a>
        <span aria-hidden="true">/</span>
        <a href={cvHref}>CV</a>
        <span aria-hidden="true">/</span>
        <a href="https://github.com/ryanb61901">GitHub</a>
      </p>
    </section>

    <section id="research" class="section-block">
      <h2>Research interests</h2>
      <p>
        I am interested in developing statistically valid and computationally practical inference methods for
        settings where limited target-domain data are supplemented by imperfect external information sources.
        This includes black-box predictors, scientific simulators, neural posterior approximations, and synthetic
        data generators.
      </p>
      <ul class="compact-list">
        {interests.map((interest) => <li>{interest}</li>)}
      </ul>
    </section>

    <section id="publications" class="section-block">
      <h2>Publications and manuscripts</h2>
      <article class="publication">
        <p class="pub-title">Miscoverage Risk Controlled Computer Model Calibration</p>
        <p><strong>Heejoon Byun</strong>, Dayeon Yoon, Won Chang.</p>
        <p class="pub-note">Manuscript in preparation; preprint expected Fall 2026.</p>
        <p>
          Develops a conformal risk control framework for calibrated posterior predictive uncertainty in
          amortized computer model calibration under data&ndash;model discrepancy.
        </p>
      </article>
      <article class="publication">
        <p class="pub-title">BlindHarmony: Blind Harmonization for MR Images via Flow Model</p>
        <p>Hwihun Jeong, <strong>Heejoon Byun</strong>, Dong Un Kang, Jongho Lee.</p>
        <p class="pub-note"><em>Proceedings of the IEEE/CVF International Conference on Computer Vision (ICCV)</em>, 2023.</p>
      </article>
    </section>

    <section id="teaching" class="section-block">
      <h2>Teaching</h2>
      <ul class="timeline">
        <li>
          <span class="date">Fall 2025</span>
          <span>Teaching Assistant, <em>Statistical Experiments with R</em>, Seoul National University.</span>
        </li>
        <li>
          <span class="date">Spring 2025</span>
          <span>Teaching Assistant, <em>Introduction to Data Science</em>, Seoul National University.</span>
        </li>
      </ul>
    </section>

    <section id="education" class="section-block">
      <h2>Education</h2>
      <ul class="timeline">
        <li>
          <span class="date">2025&ndash;2027 expected</span>
          <span>M.S. in Statistics, Seoul National University. Advisor: Won Chang.</span>
        </li>
        <li>
          <span class="date">2020&ndash;2024</span>
          <span>B.S. in Electrical and Computer Engineering, Seoul National University. <em>Summa Cum Laude.</em></span>
        </li>
      </ul>

      <h3>Selected coursework</h3>
      <ul class="compact-list coursework">
        {coursework.map((course) => <li>{course}</li>)}
      </ul>
    </section>

    <footer class="footer">
      <p>Last updated: June 2026.</p>
    </footer>
  </main>
</BaseLayout>
